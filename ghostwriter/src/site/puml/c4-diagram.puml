' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.

@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()

title Ghostwriter - C4 Component Diagram

Person(user, "User", "Runs Ghostwriter in Guidance or Act mode to process project files and workflows.")

System_Ext(localFileSystem, "Project File System", "Local source, test, documentation, configuration, temporary logs, and generated files.")
System_Ext(remoteResources, "Remote Resources", "HTTP/HTTPS and file:// sources for instructions, acts, and fetched web/API content.")
System_Ext(genaiProvider, "GenAI Provider", "External LLM service used to execute prompts and host-managed tool calls.")

System_Boundary(ghostwriter, "Ghostwriter") {
  Component(cli, "Ghostwriter CLI", "Ghostwriter", "Parses command-line options, loads runtime settings, selects Guidance or Act mode, and starts scanning.")
  Component(configuration, "Configuration", "PropertiesConfigurator / Configurator", "Loads gw.properties and runtime settings such as model, project directory, excludes, acts location, and logging options.")
  Component(layoutResolution, "Project Layout Resolution", "ProjectLayout / ProjectProcessor", "Discovers project metadata, modules, source/test/document folders, and relative paths used in prompt context.")

  Component(scanEngine, "Scanning Engine", "AbstractFileProcessor", "Traverses project and module directories, applies include/exclude matching, and delegates file or folder processing.")
  Component(aiProcessing, "AI Processing Engine", "AIFileProcessor", "Builds prompt context, resolves referenced instructions, configures the provider working directory, and performs AI requests.")

  Component(guidanceMode, "Guidance Mode", "GuidanceProcessor", "Loads reviewer implementations, extracts @guidance directives from supported files, and processes matching files or folders.")
  Component(reviewers, "Reviewer Implementations", "Reviewer SPI", "Format-specific reviewers for Java, Markdown, PUML, HTML, Python, TypeScript, and text files.")

  Component(actMode, "Act Mode", "ActProcessor / Episodes", "Loads TOML act definitions, resolves inheritance and episodes, applies act configuration, and runs episode-driven workflows.")
  Component(actRegistry, "Act Registry", "Built-in acts + custom acts", "Loads act definitions from classpath resources, custom directories, or remote locations.")
  Component(projectContext, "Project Context Tools", "ProjectContextFunctionTools", "Stores and retrieves project-scoped context variables shared across act episodes.")

  Component(toolLoader, "Provider Tool Loader", "FunctionToolsLoader", "Registers shared host tools and applies configured tool sets to the active provider.")
  Component(fileTools, "File Function Tools", "FileFunctionTools", "Provides file reads, writes, patch application, and recursive or direct directory listing utilities.")
  Component(commandTools, "Command Function Tools", "CommandFunctionTools", "Executes validated shell commands, resolves configured values, exposes command log access, and supports task termination.")
  Component(webTools, "Web Function Tools", "WebFunctionTools", "Fetches web content, reads file:// resources, and invokes REST APIs with optional headers and authentication.")
  Component(actTools, "Act Function Tools", "ActFunctionTools", "Provides act detail loading, asynchronous act execution, and result retrieval tools.")

  Component(providerManager, "Provider Management", "GenaiProviderManager", "Creates configured GenAI provider instances and tracks usage statistics.")
  Component(logging, "Logging & Input Capture", "SLF4J / docs-inputs", "Records operational events and optionally stores provider input payloads under temporary docs-inputs files.")
}

Rel(user, cli, "Invokes", "CLI")
Rel(cli, configuration, "Loads settings from")
Rel(cli, guidanceMode, "Starts")
Rel(cli, actMode, "Starts")

Rel(guidanceMode, aiProcessing, "Extends")
Rel(actMode, aiProcessing, "Extends")
Rel(aiProcessing, scanEngine, "Extends")

Rel(scanEngine, layoutResolution, "Uses project and module metadata from")
Rel(scanEngine, localFileSystem, "Scans and filters")

Rel(guidanceMode, reviewers, "Selects by file extension")
Rel(reviewers, localFileSystem, "Reads guidance-bearing files from")

Rel(actMode, actRegistry, "Loads act definitions from")
Rel(actMode, projectContext, "Shares context through")
Rel(actMode, localFileSystem, "Scans files and folders in")
Rel(actRegistry, localFileSystem, "Loads custom act files from")
Rel(actRegistry, remoteResources, "Loads remote act files from", "HTTP/HTTPS")

Rel(aiProcessing, configuration, "Reads runtime configuration from")
Rel(aiProcessing, layoutResolution, "Builds prompt context with")
Rel(aiProcessing, providerManager, "Obtains provider from")
Rel(aiProcessing, toolLoader, "Applies shared tools through")
Rel(aiProcessing, logging, "Writes logs and optional input captures to")
Rel(aiProcessing, genaiProvider, "Sends prompts to", "API")
Rel(aiProcessing, localFileSystem, "Reads referenced instruction files and writes input logs")
Rel(aiProcessing, remoteResources, "Loads referenced instruction URLs from", "HTTP/HTTPS")

Rel(toolLoader, fileTools, "Registers")
Rel(toolLoader, commandTools, "Registers")
Rel(toolLoader, webTools, "Registers")
Rel(toolLoader, actTools, "Registers")
Rel(toolLoader, projectContext, "Registers")

Rel(actTools, actRegistry, "Queries act definitions from")
Rel(actTools, actMode, "Triggers nested or background act execution in")
Rel(actTools, projectContext, "Coordinates episode context with")

Rel(fileTools, localFileSystem, "Reads/Writes")
Rel(commandTools, localFileSystem, "Runs commands within")
Rel(webTools, remoteResources, "Calls/fetches", "REST/HTTP")
Rel(webTools, localFileSystem, "Reads file:// resources from")
Rel(projectContext, localFileSystem, "Scopes context by working directory in")
Rel(providerManager, logging, "Reports usage to")

SHOW_LEGEND()
@enduml
