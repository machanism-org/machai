' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.

@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()

title Ghostwriter - C4 Component Diagram

Person(user, "User", "Runs Ghostwriter to process project files in Guidance or Act mode.")

System_Ext(genaiProvider, "GenAI Provider", "External LLM service used to execute prompts and tool calls.")
System_Ext(projectFiles, "Project File System", "Local source, documentation, configuration, and generated files.")
System_Ext(remoteResources, "Remote Resources", "HTTP/HTTPS sources for instructions, acts, and fetched web/API content.")

System_Boundary(gw, "Ghostwriter") {
  Component(cli, "Ghostwriter CLI", "Ghostwriter", "Parses command-line options, initializes configuration, resolves scan targets, and starts processing.")
  Component(config, "Configuration", "PropertiesConfigurator", "Loads gw.properties and runtime settings such as model, scan roots, excludes, acts location, and logging options.")
  Component(layout, "Project Layout Resolution", "ProjectLayout / ProjectProcessor", "Discovers project metadata, modules, and source/test/document folders used in prompts and scanning.")

  Component(scanEngine, "Scanning Engine", "AbstractFileProcessor", "Traverses project and module directories, applies include/exclude matching, and delegates folder/file work.")
  Component(aiEngine, "AI Processing Engine", "AIFileProcessor", "Builds project-context prompts, resolves instructions from text/file/URL references, configures provider working directory, and performs requests.")

  Component(guidanceMode, "Guidance Mode", "GuidanceProcessor", "Loads reviewers, extracts @guidance directives from supported files, and processes matching files or folders.")
  Component(actMode, "Act Mode", "ActProcessor", "Loads TOML act definitions, supports inheritance and prompt templating, and runs act-driven processing workflows.")

  Component(reviewers, "Reviewer Implementations", "Reviewer SPI", "Format-specific reviewers for Java, Markdown, PUML, HTML, Python, TypeScript, and text files.")
  Component(fileTools, "File Function Tools", "FileFunctionTools", "Provides file reads/writes, directory listing, recursive listing, command execution, REST calls, and web content retrieval.")
  Component(actTools, "Act Function Tools", "ActFunctionTools", "Provides built-in act discovery and act detail loading for prompts.")
  Component(providerTools, "Provider Tool Loader", "FunctionToolsLoader", "Registers reusable provider tools and applies configured tool sets to the active provider.")
  Component(providerManager, "Provider Management", "GenaiProviderManager", "Creates configured GenAI provider instances and reports usage statistics.")
  Component(logging, "Logging & Input Capture", "SLF4J / docs-inputs", "Records operational events and optionally stores prompt inputs under temporary docs-inputs files.")
}

Rel(user, cli, "Invokes", "CLI")
Rel(cli, config, "Loads settings from")
Rel(cli, layout, "Uses")
Rel(cli, guidanceMode, "Starts by default")
Rel(cli, actMode, "Starts in act mode")

Rel(guidanceMode, scanEngine, "Extends")
Rel(actMode, scanEngine, "Extends")
Rel(guidanceMode, aiEngine, "Extends")
Rel(actMode, aiEngine, "Extends")

Rel(scanEngine, layout, "Uses project/module metadata from")
Rel(scanEngine, projectFiles, "Scans and filters")
Rel(guidanceMode, reviewers, "Selects by file extension")
Rel(reviewers, projectFiles, "Reads guidance-bearing files from")

Rel(aiEngine, config, "Reads runtime configuration from")
Rel(aiEngine, layout, "Builds project context with")
Rel(aiEngine, providerManager, "Obtains provider from")
Rel(aiEngine, providerTools, "Applies shared tools through")
Rel(aiEngine, fileTools, "Applies additional tools from")
Rel(aiEngine, actTools, "Applies additional tools from")
Rel(aiEngine, logging, "Writes logs and optional input captures to")
Rel(aiEngine, genaiProvider, "Sends prompts to", "API")

Rel(actMode, projectFiles, "Loads custom acts from", "TOML files")
Rel(actMode, remoteResources, "Loads remote acts from", "HTTP/HTTPS")
Rel(actTools, projectFiles, "Reads custom act definitions from")
Rel(fileTools, projectFiles, "Reads/Writes")
Rel(fileTools, remoteResources, "Calls/fetches", "REST/HTTP")
Rel(providerManager, logging, "Reports usage to")

SHOW_LEGEND()
@enduml
