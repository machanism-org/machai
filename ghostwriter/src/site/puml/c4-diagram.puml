' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
' 
' - If a C4 Component diagram already exists, update it to accurately reflect the current architecture, components, and their relationships.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Ensure all relevant components, interfaces, and external systems are included and properly labeled.
' - Organize the diagram for readability, avoiding unnecessary complexity or clutter.
' - Save the diagram in the appropriate location as specified by the project structure.

@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

' Layout
LAYOUT_TOP_DOWN()

title Ghostwriter - C4 Component Diagram

Person(user, "User", "Runs Ghostwriter to generate/update documentation.")

System_Boundary(gw, "Ghostwriter (CLI)") {
  Component(cli, "Ghostwriter CLI", "Java", "Command-line entry point (org.machanism.machai.gw.processor.Ghostwriter): parses options, bootstraps configuration, resolves scan dirs, and orchestrates processing.")

  Component(config, "Configuration", "PropertiesConfigurator", "Loads gw.properties, resolves gw.home/gw.config, and provides settings (scanDir, excludes, instructions, model, threads, acts location, etc.).")
  Component(projectLayout, "Project Layout", "ProjectLayout", "Resolves project root and layout metadata via machai project layout utilities.")

  Component(procGuidance, "Guidance Processor", "GuidanceProcessor", "Default mode: scans documents, extracts embedded @guidance directives, builds per-file prompts and runs processing.")
  Component(procAct, "Act Processor", "ActProcessor", "Act mode: loads act definitions (TOML), renders templates, enables tool-calling, and processes files accordingly.")

  Component(filePipeline, "File Processing Pipeline", "AbstractFileProcessor", "Shared per-file pipeline: scanning, filtering/excludes, reading/writing files, reviewer selection, and GenAI request/response handling.")
  Component(reviewers, "Reviewers", "Reviewer SPI", "File-type reviewers (Java/Markdown/PUML/HTML/Python/TypeScript/Text) used for quality/safety checks and formatting guidance.")

  Component(tools, "Act Function Tools", "ActFunctionTools", "Tool endpoints exposed to the LLM during Act execution (list/load acts, file system read/write, command execution, REST/web access).")

  Component(genaiMgr, "GenAI Provider Manager", "Genai/GenaiProviderManager", "Provider selection, request dispatch, streaming, and usage accounting/logging.")
}

System_Ext(genaiProvider, "GenAI Provider", "External System", "LLM provider (e.g., OpenAI).")
System_Ext(fs, "File System", "External System", "Local source/docs files scanned and updated by Ghostwriter.")
System_Ext(net, "External URLs", "External System", "URLs used for instruction loading or web content retrieval.")

Rel(user, cli, "Invokes", "CLI")

Rel(cli, config, "Initializes/loads", "gw.properties")
Rel(cli, projectLayout, "Resolves", "project root/layout")

Rel(cli, procGuidance, "Runs", "default")
Rel(cli, procAct, "Runs", "-a/--act")

Rel(procGuidance, filePipeline, "Uses")
Rel(procAct, filePipeline, "Uses")

Rel(filePipeline, reviewers, "Selects/uses", "by file type")
Rel(filePipeline, genaiMgr, "Submits prompts/results")
Rel(filePipeline, fs, "Reads/Writes", "local files")

Rel(procAct, tools, "Enables", "tool calling")
Rel(tools, fs, "Reads/Writes", "files")
Rel(tools, net, "Fetches", "HTTP")

Rel(genaiMgr, genaiProvider, "Calls", "HTTPS/API")

@enduml
