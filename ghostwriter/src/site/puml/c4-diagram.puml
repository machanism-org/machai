' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
' 
' - If a C4 Component diagram already exists, update it to accurately reflect the current architecture, components, and their relationships.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Ensure all relevant components, interfaces, and external systems are included and properly labeled.
' - Organize the diagram for readability, avoiding unnecessary complexity or clutter.
' - Save the diagram in the appropriate location as specified by the project structure.

@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

' Layout
LAYOUT_TOP_DOWN()

title Ghostwriter - C4 Component Diagram

Person(user, "User", "Runs Ghostwriter to generate/update documentation.")

System_Boundary(gw, "Ghostwriter (CLI)") {
  Component(cli, "Ghostwriter CLI", "Java", "Parses CLI options, loads configuration, orchestrates scanning and processing.")

  Component(procOrch, "File Processing Orchestrator", "Java", "Drives scanning, selects processing mode (Guidance vs Act), applies excludes, and manages concurrency.")

  Component(guidanceProc, "GuidanceProcessor", "Java", "Extracts embedded @guidance directives from files and builds prompts.")
  Component(actProc, "ActProcessor", "Java", "Executes predefined Act prompts from TOML act definitions.")

  Component(absFileProc, "AbstractFileProcessor", "Java", "Shared scanning and per-file processing behavior; delegates to reviewers and GenAI.")

  Component(reviewers, "Reviewers", "Java", "Language-specific reviewers for content quality and safety (Java/Markdown/PUML/etc.).")

  Component(tools, "ActFunctionTools", "Java", "Function tools exposed to the LLM for Act execution (e.g., act listing/apply).")

  Component(genaiMgr, "GenAI Integration", "Java", "Provider selection, request dispatch, and usage accounting via Genai/GenaiProviderManager.")

  Component(config, "Configuration", "Properties", "Loads gw.properties and resolves instructions, scanDir, excludes, model.")

  Component(projectLayout, "ProjectLayout", "Library", "Resolves project root and layout metadata.")
}

System_Ext(genaiProvider, "GenAI Provider", "External System", "LLM provider (e.g., OpenAI).")
System_Ext(fs, "File System", "External System", "Source/docs files scanned and updated by Ghostwriter.")

Rel(user, cli, "Invokes", "CLI")

Rel(cli, config, "Loads", "gw.properties")
Rel(cli, projectLayout, "Resolves project root", "project-layout")
Rel(cli, procOrch, "Orchestrates")

Rel(procOrch, absFileProc, "Uses")
Rel(procOrch, guidanceProc, "Uses (default mode)")
Rel(procOrch, actProc, "Uses (Act mode)")

Rel(absFileProc, reviewers, "Uses", "Reviewer SPI")
Rel(absFileProc, genaiMgr, "Submits prompts/results")
Rel(actProc, tools, "Exposes tools to LLM")
Rel(genaiMgr, genaiProvider, "Calls", "HTTPS/API")

Rel(absFileProc, fs, "Reads/Writes", "Local files")

@enduml
