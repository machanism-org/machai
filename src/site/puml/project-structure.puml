' @guidance: For each module, use information from its pom.xml file to create a PlantUML dependency diagram.
@startuml

title Machai Project - Module Dependencies

skinparam backgroundColor transparent
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultTextAlignment left

skinparam component {
  BackgroundColor #EEF6FF
  BorderColor #2E5EAA
  FontColor #0B1F44
}

skinparam arrow {
  Color #2E5EAA
  Thickness 1
}

legend left
  <b>Legend</b>
  A --> B : A depends on B
  A ..> B : A includes B as a Maven module
endlegend

component "machai\n(root pom)" as machai_root <<pom>>
component "project-layout" as project_layout
component "genai-client" as genai_client
component "bindex-core" as bindex_core
component "machai-cli" as machai_cli
component "ghostwriter" as ghostwriter
component "gw-maven-plugin" as gw_maven_plugin

machai_root ..> project_layout : module
machai_root ..> genai_client : module
machai_root ..> bindex_core : module
machai_root ..> machai_cli : module
machai_root ..> ghostwriter : module
machai_root ..> gw_maven_plugin : module

' Dependencies between modules (from module pom.xml)

genai_client --> project_layout

bindex_core --> project_layout
bindex_core --> genai_client

ghostwriter --> project_layout
ghostwriter --> genai_client
ghostwriter --> bindex_core

machai_cli --> bindex_core
machai_cli --> ghostwriter

gw_maven_plugin --> ghostwriter

@enduml
