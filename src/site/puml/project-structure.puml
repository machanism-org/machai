@startuml

title Machai Project - Module Dependencies

skinparam backgroundColor transparent
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultTextAlignment left

skinparam component {
  BackgroundColor #EEF6FF
  BorderColor #2E5EAA
  FontColor #0B1F44
}

skinparam arrow {
  Color #2E5EAA
  Thickness 1
}

legend left
  <b>Legend</b>
  A --> B : A depends on B
  A ..> B : parent POM includes B as a Maven module
  A -up-|> B : A inherits from parent POM B
  A ..> B : dependency active only in a Maven profile
endlegend

component "machai\n(root pom)" as machai_root <<pom>>
component "project-layout" as project_layout
component "genai-client" as genai_client
component "machai-mcp-server" as mcp_server
component "mcp-server-maven-plugin" as mcp_server_maven_plugin <<maven-plugin>>
component "bindex-core" as bindex_core
component "ghostwriter" as ghostwriter
component "gw-maven-plugin" as gw_maven_plugin <<maven-plugin>>

machai_root ..> project_layout : module
machai_root ..> genai_client : module
machai_root ..> mcp_server : module
machai_root ..> mcp_server_maven_plugin : module
machai_root ..> bindex_core : module
machai_root ..> ghostwriter : module
machai_root ..> gw_maven_plugin : module

project_layout -up-|> machai_root : parent

genai_client -up-|> machai_root : parent

mcp_server -up-|> machai_root : parent
mcp_server --> genai_client

mcp_server_maven_plugin -up-|> machai_root : parent
mcp_server_maven_plugin --> mcp_server

bindex_core -up-|> machai_root : parent
bindex_core --> genai_client

ghostwriter -up-|> machai_root : parent
ghostwriter --> project_layout
ghostwriter --> genai_client
ghostwriter ..> bindex_core : pack profile dependency

gw_maven_plugin -up-|> machai_root : parent
gw_maven_plugin --> ghostwriter

@enduml
