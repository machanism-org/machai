' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.
@startuml ProjectLayoutComponentDiagram
!include <C4/C4_Component>

LAYOUT_WITH_LEGEND()

title Project Layout - Component Diagram

Person(developer, "Developer / Tool Integrator", "Uses project layout APIs to detect, inspect, and process project structures.")

System_Ext(fileSystem, "Project File System", "Project directories, build descriptors, source roots, test roots, documentation roots, and modules.")
System_Ext(mavenPom, "Maven pom.xml", "Maven build metadata parsed with Apache Maven Model APIs.")
System_Ext(logging, "SLF4J Logging", "Application logging facade used for processing and diagnostics.")

Container_Boundary(projectLayoutLib, "org.machanism.machai.project") {
    Component(projectProcessor, "ProjectProcessor", "Abstract Java component", "Scans project folders, detects modules, and delegates project-specific folder processing to subclasses.")
    Component(projectLayoutManager, "ProjectLayoutManager", "Java utility", "Detects the concrete ProjectLayout implementation by inspecting project files and directories.")

    Component(projectLayout, "ProjectLayout", "Abstract Java component", "Defines the common contract for project roots, modules, source directories, test directories, documentation directories, relative paths, exclusions, and temporary directory handling.")

    Component(defaultLayout, "DefaultProjectLayout", "Java component", "Fallback layout that treats immediate non-excluded subdirectories as modules and exposes empty source, test, and documentation roots.")
    Component(mavenLayout, "MavenProjectLayout", "Java component", "Reads Maven metadata to expose modules, source roots, test roots, documentation roots, project identifiers, names, and parent identifiers.")
    Component(gradleLayout, "GragleProjectLayout", "Java component", "Detects Gradle projects and provides Gradle-oriented project layout information.")
    Component(jsLayout, "JScriptProjectLayout", "Java component", "Detects package.json-based JavaScript projects and provides JavaScript-oriented layout information.")
    Component(pythonLayout, "PythonProjectLayout", "Java component", "Detects Python projects and provides Python-oriented layout information.")
    Component(pomReader, "PomReader", "Java component", "Parses Maven pom.xml files into Maven Model objects used by MavenProjectLayout.")
}

Rel(developer, projectProcessor, "Starts project scanning with", "Java API")
Rel(developer, projectLayoutManager, "Requests direct layout detection from", "Java API")

Rel(projectProcessor, projectLayoutManager, "Detects project layout through")
Rel(projectProcessor, projectLayout, "Processes folders using detected layout contract")
Rel(projectProcessor, projectProcessor, "Recursively processes detected modules")

Rel(projectLayoutManager, fileSystem, "Checks project root existence and marker files", "java.io.File")
Rel(projectLayoutManager, mavenLayout, "Creates when pom.xml exists")
Rel(projectLayoutManager, gradleLayout, "Creates when Gradle markers exist")
Rel(projectLayoutManager, jsLayout, "Creates when package.json exists")
Rel(projectLayoutManager, pythonLayout, "Creates when Python markers exist")
Rel(projectLayoutManager, defaultLayout, "Creates when no specific layout matches")

Rel_U(defaultLayout, projectLayout, "Extends")
Rel_U(mavenLayout, projectLayout, "Extends")
Rel_U(gradleLayout, projectLayout, "Extends")
Rel_U(jsLayout, projectLayout, "Extends")
Rel_U(pythonLayout, projectLayout, "Extends")

Rel(projectLayout, fileSystem, "Lists files/directories, computes relative paths, and excludes build/tool directories", "java.io.File")
Rel(projectLayout, logging, "Logs temporary directory initialization")
Rel(defaultLayout, fileSystem, "Reads immediate child directories")
Rel(mavenLayout, pomReader, "Uses to parse Maven model")
Rel(pomReader, mavenPom, "Reads and parses", "pom.xml")
Rel(mavenLayout, mavenPom, "Derives modules and build paths from", "Maven Model")

SHOW_LEGEND()
@enduml
