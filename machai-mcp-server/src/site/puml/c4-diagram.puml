' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.
@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_LEFT_RIGHT()

title Machai MCP Server - C4 Component Diagram

Person(client, "MCP Client", "IDE, AI assistant, or external process consuming the MCP server")
System_Ext(projectWorkspace, "Project Workspace", "Target project directory supplied directly or resolved from client requests")
System_Ext(toolImplementations, "Machai Tool Implementations", "Function-based tools discovered and loaded by FunctionToolsLoader")
System_Ext(mcpJavaSdk, "MCP Java SDK", "Model Context Protocol server framework, transports, capabilities, and schema types")
System_Ext(jettyServer, "Jetty HTTP Server", "Embedded servlet container used by HTTP MCP transports")
System_Ext(cliRuntime, "CLI Runtime", "Command-line environment providing startup arguments and process lifecycle")

System_Boundary(machaiMcpServer, "Machai MCP Server") {
  Component(entryPoint, "McpServer", "Java main class", "Parses CLI options, resolves project directory, selects transport mode, and starts the chosen MCP server")
  Component(serverAbstraction, "AbstractMcpServer", "Abstract base class", "Defines shared server lifecycle, project-directory context, configurator wiring, and tool specification builder contract")
  Component(httpBase, "AbstractHttpMcpServer", "Abstract HTTP server base", "Creates and starts embedded Jetty, configures the connector, and mounts MCP servlet transports")
  Component(stdioServer, "StdioMcpServer", "STDIO MCP server", "Builds the single-session STDIO MCP server, capabilities, prompts, and tools")
  Component(httpStatelessServer, "HttpStatelessMcpServer", "HTTP stateless MCP server", "Builds stateless HTTP MCP server capabilities, prompt handlers, and tool registrations")
  Component(httpStreamableServer, "HttpStreamableMcpServer", "HTTP streamable MCP server", "Builds streamable HTTP MCP server capabilities, session-aware prompts, and tool registrations")
  Component(genericAdapter, "GenericGenaiAdapter", "Tool adapter", "Transforms Machai tool metadata into MCP tool specifications, JSON schemas, call handlers, and execution results")
  Component(stdioAdapter, "StdioGenaiAdapter", "STDIO prompt adapter", "Registers STDIO prompt specifications and executes prompt-backed tool functions")
  Component(httpStatelessAdapter, "HttpStatelessGenericGenaiAdapter", "Stateless HTTP prompt adapter", "Registers stateless HTTP prompt specifications and executes prompt-backed tool functions")
  Component(httpStreamableAdapter, "HttpStreamableGenericGenaiAdapter", "Streamable HTTP prompt adapter", "Registers streamable HTTP prompt specifications and adds session IDs to prompt execution arguments")
}

Rel(client, entryPoint, "Starts or connects to", "CLI, STDIO, or HTTP")
Rel(cliRuntime, entryPoint, "Supplies startup options", "CLI arguments")
Rel(entryPoint, serverAbstraction, "Creates and configures selected server")
Rel(entryPoint, stdioServer, "Starts when no port is provided")
Rel(entryPoint, httpStatelessServer, "Starts when --port is set")
Rel(entryPoint, httpStreamableServer, "Starts when --port and --session are set")

Rel(serverAbstraction, projectWorkspace, "Stores and exposes project directory context for tool execution")
Rel(serverAbstraction, toolImplementations, "Loads available tools and prompts through", "FunctionToolsLoader")
Rel(httpStatelessServer, httpBase, "Extends")
Rel(httpStreamableServer, httpBase, "Extends")
Rel(httpBase, jettyServer, "Starts embedded HTTP runtime using")

Rel(stdioServer, stdioAdapter, "Uses to register tools and prompts")
Rel(httpStatelessServer, httpStatelessAdapter, "Uses to register tools and prompts")
Rel(httpStreamableServer, httpStreamableAdapter, "Uses to register tools and prompts")
Rel(stdioAdapter, genericAdapter, "Extends for shared tool registration")
Rel(httpStatelessAdapter, genericAdapter, "Extends for shared tool registration")
Rel(httpStreamableAdapter, genericAdapter, "Extends for shared tool registration")
Rel(genericAdapter, toolImplementations, "Delegates tool execution through", "ToolFunction")
Rel(genericAdapter, projectWorkspace, "Passes project directory into tool execution context")

Rel(stdioServer, mcpJavaSdk, "Builds sync server and STDIO transport with")
Rel(httpStatelessServer, mcpJavaSdk, "Builds stateless sync server and HTTP transport with")
Rel(httpStreamableServer, mcpJavaSdk, "Builds streamable sync server and HTTP transport with")
Rel(stdioAdapter, mcpJavaSdk, "Creates prompt and tool specifications using")
Rel(httpStatelessAdapter, mcpJavaSdk, "Creates stateless prompt and tool specifications using")
Rel(httpStreamableAdapter, mcpJavaSdk, "Creates streamable prompt and tool specifications using")

Rel(stdioServer, client, "Exchanges MCP messages with", "stdin/stdout")
Rel(httpStatelessServer, client, "Serves MCP requests for", "HTTP")
Rel(httpStreamableServer, client, "Serves MCP requests for", "HTTP streamable")

SHOW_LEGEND()
@enduml
