<configuration>
    <!-- Define only a file appender, or leave empty for no logging at all -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/bindex.log</file>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <!-- Remove any <appender-ref ref="STDOUT" /> or similar console appenders -->
        <appender-ref ref="FILE" />
    </root>
</configuration>