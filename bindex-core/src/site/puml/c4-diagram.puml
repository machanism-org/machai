' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
' 
' - If a C4 Component diagram already exists, update it to accurately reflect the current architecture, components, and their relationships.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Ensure all relevant components, interfaces, and external systems are included and properly labeled.
' - Organize the diagram for readability, avoiding unnecessary complexity or clutter.
' - Save the diagram in the appropriate location as specified by the project structure.

@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Bindex Core (bindex-core) - C4 Component Diagram

Person(user, "Developer / Automation", "Invokes Bindex generation, registration and semantic picking.")

System_Boundary(bc, "Bindex Core") {
  Component(bindexCreator, "BindexCreator", "Java", "Creates/updates bindex.json for a project using an AI-assisted BindexBuilder.")
  Component(bindexRegister, "BindexRegister", "Java", "Registers a project's bindex.json into the Bindex registry.")
  Component(bindexProjectProcessor, "BindexProjectProcessor", "Java", "Shared utilities to locate and parse bindex.json within a project directory.")

  Component(bindexBuilderFactory, "BindexBuilderFactory", "Java", "Selects a BindexBuilder based on detected ProjectLayout (Maven/JS/Python/Generic).")

  Component(bindexBuilder, "BindexBuilder", "Java", "Builds a Bindex using project context + LLM prompts (base builder).")
  Component(mavenBuilder, "MavenBindexBuilder", "Java", "Maven-specific BindexBuilder.")
  Component(jsBuilder, "JScriptBindexBuilder", "Java", "JavaScript-specific BindexBuilder.")
  Component(pyBuilder, "PythonBindexBuilder", "Java", "Python-specific BindexBuilder.")

  Component(picker, "Picker", "Java", "Registers and retrieves Bindexes via MongoDB and performs semantic vector search.")
  Component(bindexRepository, "BindexRepository", "Java", "MongoDB-backed persistence for Bindex documents.")

  Component(functionTools, "BindexFunctionTools", "Java", "Registers GenAI function tools: get_bindex, get_bindex_schema, pick_libraries.")
}

System_Ext(genai, "GenAI Provider", "LLM/Embeddings", "Provides prompting and embedding generation.")
System_Ext(mongo, "MongoDB Atlas", "Database", "Stores Bindex documents and vector embeddings.")
System_Ext(projectFs, "Project Folder", "File System", "Contains project sources and bindex.json.")

Rel(user, bindexCreator, "Generates/updates bindex.json")
Rel(user, bindexRegister, "Registers bindex.json")
Rel(user, picker, "Performs semantic pick")

Rel(bindexCreator, bindexBuilderFactory, "Selects builder")
Rel(bindexBuilderFactory, bindexBuilder, "Creates", "when layout is unknown")
Rel(bindexBuilderFactory, mavenBuilder, "Creates", "for Maven")
Rel(bindexBuilderFactory, jsBuilder, "Creates", "for JavaScript")
Rel(bindexBuilderFactory, pyBuilder, "Creates", "for Python")

Rel(bindexCreator, bindexProjectProcessor, "Reads existing bindex.json")
Rel(bindexCreator, projectFs, "Writes", "bindex.json")
Rel(bindexProjectProcessor, projectFs, "Reads", "bindex.json")

Rel(bindexRegister, bindexProjectProcessor, "Reads", "bindex.json")
Rel(bindexRegister, picker, "Registers Bindex")

Rel(picker, genai, "Prompts + embeddings")
Rel(picker, mongo, "Reads/writes", "Bindex documents + embeddings")

Rel(bindexRepository, mongo, "Reads/writes", "Bindex documents")

Rel(functionTools, genai, "Registers tools")
Rel(functionTools, bindexRepository, "Fetches", "Bindex by id")
Rel(functionTools, picker, "Invokes", "pick_libraries")

@enduml
