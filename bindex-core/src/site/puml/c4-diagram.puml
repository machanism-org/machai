' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists, update it to accurately reflect the current architecture, key components, and their relationships.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems: `mongodb`, `genaiProvider`, `fileSystem`; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.
@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_LEFT_RIGHT()

title Bindex Core - C4 Component Diagram

Person(user, "Developer / Build Process", "Invokes Bindex function tools and library recommendation workflows")
System_Ext(fileSystem, "Working Directory", "Provides Bindex JSON files for registration requests")
System_Ext(genaiProvider, "GenAI Provider", "Performs classification prompts and embedding generation")
System_Ext(mongodb, "MongoDB", "Stores registered Bindex documents and supports vector-search retrieval")

System_Boundary(bindexCore, "Bindex Core") {
  Component(bindexFunctionTools, "BindexFunctionTools", "Java / FunctionTools", "Registers AI-callable tools for Bindex lookup, schema retrieval, recommendation, and file-based registration")
  Component(picker, "Picker", "Java", "Creates classification embeddings, stores Bindex records, classifies prompts, and performs semantic library selection")
  Component(repository, "BindexRepository", "Java", "Creates MongoDB collection access and provides Bindex lookup and deletion operations")
}

Rel(user, bindexFunctionTools, "Calls exposed Bindex tools")
Rel(user, picker, "Uses recommendation and registration workflows")

Rel(bindexFunctionTools, repository, "Reads Bindex documents through")
Rel(bindexFunctionTools, picker, "Delegates recommendation and registration to")
Rel(bindexFunctionTools, fileSystem, "Reads Bindex JSON files from")

Rel(picker, genaiProvider, "Sends classification prompts and embedding requests to")
Rel(picker, mongodb, "Stores records and runs vector searches in")
Rel(picker, repository, "Shares repository-backed collection access with")

Rel(repository, mongodb, "Creates client connections to")

SHOW_LEGEND()
@enduml
