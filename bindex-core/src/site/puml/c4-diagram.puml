' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists, update it to accurately reflect the current architecture, key components, and their relationships.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems: `mongodb`, `genaiProvider`, `fileSystem`; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.
@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_LEFT_RIGHT()

title Bindex Core - C4 Component Diagram

Person(user, "Developer / Build Process", "Uses Bindex APIs or AI-callable tools to retrieve metadata, register Bindex records, and request library recommendations")
System_Ext(fileSystem, "Working Directory", "Contains bindex.json or other Bindex JSON files used for file-based registration")
System_Ext(genaiProvider, "GenAI Provider", "Classifies natural-language requirements and generates classification embedding vectors")
System_Ext(mongodb, "MongoDB", "Stores serialized Bindex documents, indexed classification metadata, and vector embeddings")

System_Boundary(bindexCore, "Bindex Core") {
  Component(bindexFunctionTools, "BindexFunctionTools", "Java / FunctionTools", "Exposes AI-callable tools: get_bindex, pick_libraries, register_bindex, and register_bindex_json")
  Component(picker, "Picker", "Java", "Orchestrates Bindex registration and recommendation workflows, builds classification prompts, generates embeddings, and traverses dependencies")
  Component(repositoryInterface, "BindexRepository", "Java Interface", "Defines Bindex lookup, save, and semantic recommendation repository operations")
  Component(mongoRepository, "MongoBindexRepository", "Java / MongoDB Driver", "Persists Bindex documents, maintains searchable metadata, and performs MongoDB vector-search queries")
}

Rel(user, bindexFunctionTools, "Invokes AI-callable Bindex tools")
Rel(user, picker, "Can call direct registration or recommendation APIs")

Rel(bindexFunctionTools, fileSystem, "Reads Bindex JSON registration files from")
Rel(bindexFunctionTools, picker, "Creates and delegates registration and recommendation workflows to")
Rel(bindexFunctionTools, repositoryInterface, "Uses repository for lookup, registration, and recommendation")

Rel(picker, genaiProvider, "Requests prompt classification and embeddings from")
Rel(picker, repositoryInterface, "Uses for Bindex persistence, lookup, dependency resolution, and semantic search")
Rel(mongoRepository, repositoryInterface, "Implements")
Rel(mongoRepository, mongodb, "Connects to collection, stores Bindex documents, and executes vector-search aggregation pipelines in")

SHOW_LEGEND()
@enduml
