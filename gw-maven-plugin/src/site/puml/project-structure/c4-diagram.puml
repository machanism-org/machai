' @guidance:
' Create or update the C4 Component-level PlantUML diagram for the project.
'
' - If a C4 Component diagram already exists.
' - If no diagram exists, generate a new one that clearly represents all major components, their responsibilities, and interactions within the project.
' - Use PlantUML C4-PlantUML syntax and best practices for clarity and maintainability.
' - Include only relevant components from `/src/main/java` and external systems; remove or omit unnecessary details.
' - Organize the diagram for readability, avoiding complexity and clutter.
' - Add SHOW_LEGEND() at the end of the puml code.
@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title GW Maven Plugin - C4 Component Diagram

Person(developer, "Developer", "Runs Maven goals to automate guided documentation workflows")
System_Ext(mavenRuntime, "Maven Runtime", "Provides plugin execution context, reactor session, settings, and project metadata")
System_Ext(genaiProvider, "GenAI Provider", "Executes Ghostwriter prompts and acts through the Machai AI provider")
System_Ext(fileSystem, "Project File System", "Hosts source, documentation, generated files, build outputs, and temporary workflow artifacts")
System_Ext(mavenRepositories, "Maven Repositories", "Provide dependency artifacts that contribute to the plugin classpath and class metadata inspection")
System_Ext(interactiveUserInput, "Interactive Console Input", "Collects action prompts from the user through Maven's prompter during interactive act execution")

System_Boundary(gwPlugin, "GW Maven Plugin") {
  Component(pluginGoals, "Plugin Goals", "GWMojo, GWPerModuleMojo, ActMojo, ActPerModuleMojo, CleanMojo", "Exposes guided scan, per-module scan, interactive act, per-module act, and cleanup Maven goals")
  Component(sharedMojoBase, "Shared Mojo Base", "AbstractGWMojo", "Centralizes Maven parameter handling, settings-based credential resolution, shared scan configuration, and common execution flow")
  Component(guidedProcessing, "Guided Processing Pipeline", "GuidanceProcessor", "Scans guided files, applies workflow instructions, and orchestrates guided document processing")
  Component(actProcessing, "Act Processing Pipeline", "ActProcessor", "Executes interactive or predefined acts against scanned project content and supports console-driven input")
  Component(cleanupProcessing, "Cleanup Processing", "CleanMojo + GuidanceProcessor.deleteTempFiles", "Deletes temporary workflow artifacts created during guided processing")
  Component(classTools, "Class Introspection Tools", "ClassFunctionalTools", "Registers AI function tools for class discovery and reflective metadata lookup")
  Component(classMetadata, "Class Metadata Resolver", "ClassInfoHolder", "Builds project classloaders, scans classes from outputs and dependencies, and maps classes to source paths and artifacts")
}

Rel(developer, pluginGoals, "Invokes Maven goals", "mvn gw:gw / gw:gw-per-module / gw:act / gw:act-per-module / clean")
Rel(mavenRuntime, pluginGoals, "Creates and configures mojos")
Rel(pluginGoals, sharedMojoBase, "Uses shared configuration and scan flow", "gw / gw-per-module / act / act-per-module")
Rel(pluginGoals, guidedProcessing, "Runs guided document processing", "gw / gw-per-module")
Rel(pluginGoals, actProcessing, "Runs act-based processing", "act / act-per-module")
Rel(pluginGoals, cleanupProcessing, "Triggers temporary file cleanup", "clean")
Rel(sharedMojoBase, mavenRuntime, "Reads session, settings, project, reactor projects, and execution root")
Rel(sharedMojoBase, guidedProcessing, "Supplies excludes, instructions, logging, scan roots, and registered tools")
Rel(sharedMojoBase, actProcessing, "Supplies shared configuration, logging, scan roots, and registered tools")
Rel(sharedMojoBase, classTools, "Registers class-aware tools when Maven project context exists")
Rel(guidedProcessing, genaiProvider, "Sends workflow prompts and scanned content")
Rel(actProcessing, genaiProvider, "Sends act prompts and scanned content")
Rel(actProcessing, interactiveUserInput, "Prompts for act text and follow-up input when needed")
Rel(guidedProcessing, fileSystem, "Scans and updates guided files")
Rel(actProcessing, fileSystem, "Scans and updates guided files")
Rel(cleanupProcessing, fileSystem, "Deletes temporary workflow files")
Rel(classTools, classMetadata, "Creates and queries cached project class metadata")
Rel(classMetadata, fileSystem, "Reads source roots, compiled classes, and build output directories")
Rel(classMetadata, mavenRepositories, "Inspects dependency jars and artifact coordinates")
Rel(guidedProcessing, classTools, "Uses function tools for class lookup and reflection metadata")
Rel(actProcessing, classTools, "Uses function tools for class lookup and reflection metadata")

SHOW_LEGEND()
@enduml
